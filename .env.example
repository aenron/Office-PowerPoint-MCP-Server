# Docker Compose host port mapped to container port 8000.
MCP_PORT=8000

# Public base URL used in generated download links.
# Change this when exposing the service through a domain, reverse proxy, or public IP.
DOWNLOAD_URL=http://localhost:8000

# Comma-separated Host header allowlist for FastMCP DNS rebinding protection.
# Include every hostname/IP and port clients will use to access the SSE service.
MCP_ALLOWED_HOSTS=localhost:8000,127.0.0.1:8000,ppt-mcp-sse:8000

# Template search path inside the container.
# The default compose file mounts local templates into /app/templates.
PPT_TEMPLATE_PATH=/app/templates
